<Window x:Class="Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GamingOverlay Launcher"
        Width="920"
        Height="560"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource LauncherBackground}">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#001018"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="GamingOverlay"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="32"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding VersionText}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13"
                           Margin="2,4,0,0"/>
            </StackPanel>
            <Border DockPanel.Dock="Right"
                    BorderBrush="{StaticResource PanelBorder}"
                    Background="{StaticResource PanelBackground}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,9">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="13"/>
            </Border>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,30,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{StaticResource PanelBorder}"
                    Background="{StaticResource PanelBackground}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Changelog"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding Changelog}"
                                   Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="21"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{StaticResource PanelBorder}"
                    Background="{StaticResource PanelBackground}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22">
                <StackPanel>
                    <TextBlock Text="Overlay"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding OverlayState}"
                               Foreground="{StaticResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,12,0,24"/>
                    <Button Content="{Binding PrimaryButtonText}"
                            IsEnabled="{Binding CanRunPrimaryAction}"
                            Click="PrimaryButton_Click"/>
                    <Button Content="Check updates"
                            Margin="0,12,0,0"
                            Background="#182130"
                            BorderBrush="{StaticResource PanelBorder}"
                            Foreground="{StaticResource TextPrimary}"
                            IsEnabled="{Binding CanRunPrimaryAction}"
                            Click="CheckButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2">
            <ProgressBar Height="8"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding Progress}"
                         Foreground="{StaticResource Accent}"
                         Background="#141923"/>
            <TextBlock Text="{Binding ProgressText}"
                       Foreground="{StaticResource TextMuted}"
                       FontSize="12"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>

