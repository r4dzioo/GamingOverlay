<Application x:Class="Launcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="LauncherBackground" Color="#090B10"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#121722"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#243044"/>
        <SolidColorBrush x:Key="Accent" Color="#0DD1FF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#2AD9FF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#EAF2F8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8EA0AF"/>
    </Application.Resources>
</Application>

